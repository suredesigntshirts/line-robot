---
import {
  getDb,
  listPublicProvinces,
  type PublicCardRow,
  searchPublicListings,
} from "@line-robot/db";
import { createTranslator, ErrorState, type UiLocale } from "@line-robot/ui";
import { createElement } from "react";
import { BrowseResults, type CardRow } from "../components/BrowseResults.tsx";
import { FilterBar } from "../components/FilterBar.tsx";
import { NearMe } from "../components/NearMe.tsx";
import { ResultsMap } from "../components/ResultsMap.tsx";
import Base from "../layouts/Base.astro";
import { parseBrowseQuery } from "../lib/browse.ts";
import { presignThumbs } from "../lib/media.ts";

// S4-I2: the browse page — consented listings (LEGAL-02) from Postgres with
// filters + pagination. Shared by the th (/) and en (/en/) routes.
interface Props {
  locale: UiLocale;
}
const { locale } = Astro.props;
const t = createTranslator(locale);
const basePath = locale === "en" ? "/en" : "";
const PAGE_SIZE = 24;

// COPY-07 "next" for the SSR error state (a JSX prop can't be written in an Astro template).
// Keep the query string so a retry after a transient DB error preserves the user's filters.
const retryLink = createElement(
  "a",
  { href: `${Astro.url.pathname}${Astro.url.search}` },
  t("error.retry"),
);

const query = parseBrowseQuery(Astro.url.searchParams);
let cards: CardRow[] = [];
let total = 0;
let provinces: string[] = [];
let dbError = false;
try {
  const result = await searchPublicListings(getDb(), {
    lang: locale,
    dealType: query.dealType,
    propertyType: query.propertyType,
    listingType: query.listingType,
    saleCondition: query.saleCondition,
    province: query.province,
    text: query.text,
    // CONV-08: a radius search (?lat&lng&radius) restricts to listings near the point, nearest first.
    near: query.near && {
      lat: query.near.lat,
      lon: query.near.lng,
      radiusM: query.near.radiusM,
    },
    page: query.page,
    pageSize: PAGE_SIZE,
  });
  // Presign each card's hero thumb (4.1). Done in the page (async) — the card is a sync SSR island.
  const heroUrls = await presignThumbs(result.rows.map((r: PublicCardRow) => r.heroThumbKey));
  cards = result.rows.map((r: PublicCardRow, i: number) => ({ ...r, heroUrl: heroUrls[i] ?? null }));
  total = result.total;
  query.page = result.page; // repo clamps out-of-range deep links to the last page
  try {
    provinces = await listPublicProvinces(getDb());
  } catch {
    /* chips degrade to none; results still render */
  }
} catch (error) {
  // Render degrades to an error state rather than a 500 (DB down / not configured).
  console.error("browse query failed:", error);
  dbError = true;
}

// CONV-08: on a radius search, a supplementary map of the result pins (only listings with coords).
// TECH-01: it's a lazy island, so the static list keeps its zero-JS; the list stays primary.
const showMap = query.near !== undefined && !dbError;
const pins = showMap
  ? cards
      .filter((c) => c.lat !== null && c.lon !== null)
      .map((c) => ({
        id: c.listing.id,
        lat: c.lat as number,
        lng: c.lon as number,
        title: c.headline,
        href: `${basePath}/properties/${c.listing.id}`,
      }))
  : [];
---

<Base
  title={t("home.title")}
  description={t("home.description")}
  canonicalPath={locale === "en" ? "/en/" : "/"}
>
  <main
    data-rendered-at={new Date().toISOString()}
    style="max-width: 72rem; margin: 0 auto; padding: var(--spacing-4); display: grid; gap: var(--spacing-4);"
  >
    <h1 style="font-size: var(--text-2xl); font-family: var(--font-heading-th); margin: 0;">
      {t("home.title")}
    </h1>
    <FilterBar client:load query={query} locale={locale} basePath={basePath} provinces={provinces} />
    <NearMe client:load query={query} locale={locale} basePath={basePath} />
    {
      dbError ? (
        <ErrorState t={t} action={retryLink} />
      ) : (
        <BrowseResults
          rows={cards}
          total={total}
          query={query}
          pageSize={PAGE_SIZE}
          locale={locale}
          basePath={basePath}
        />
      )
    }
    {
      showMap && pins.length > 0 && (
        <ResultsMap client:visible pins={pins} locale={locale} />
      )
    }
  </main>
</Base>
