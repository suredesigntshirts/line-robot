---
import "@line-robot/ui/theme.css";
// theme.css declares tokens inside Tailwind v4 `@theme {}`; the website doesn't run
// Tailwind, so a browser discards that block and every var(--token) would be empty
// (serif font, no spacing/colour). fallbacks.css restates them as a plain :root
// (hex-first + @supports OKLCH). Import AFTER theme.css so its dark-mode blocks win.
import "@line-robot/ui/fallbacks.css";
import ogDefault from "../assets/og-default.png";

interface Props {
  title: string;
  description: string;
  /** Canonical path for this page ("/properties/123"); joined onto the site origin. */
  canonicalPath: string;
  /** Absolute og:image URL (a presigned listing hero on detail pages). Omit → site default. */
  ogImage?: string;
}

const { title, description, canonicalPath, ogImage } = Astro.props;
const locale = Astro.currentLocale ?? "th";
// astro.config.mjs always sets `site` (SITE_URL or its placeholder default).
const site = Astro.site;
if (!site) throw new Error("Astro.site missing — set `site` in astro.config.mjs");
const canonical = new URL(canonicalPath, site);
// hreflang pair: default locale lives at "/", English under "/en/".
const thUrl = new URL(canonicalPath.replace(/^\/en(\/|$)/, "/"), site);
const enPath = canonicalPath.startsWith("/en/") ? canonicalPath : `/en${canonicalPath}`;
const enUrl = new URL(enPath, site);
// og:image: the page's hero (presigned, already absolute) or the branded site default. `ogDefault.src`
// is the build-hashed /_astro/* path (CloudFront-served); make it absolute on the origin for sharing.
const usingDefaultOg = !ogImage;
const ogImageUrl = ogImage ?? new URL(ogDefault.src, site).href;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="th" href={thUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    {usingDefaultOg && <meta property="og:image:width" content="1200" />}
    {usingDefaultOg && <meta property="og:image:height" content="630" />}
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
  </head>
  <body style="margin: 0; background: var(--color-bg); color: var(--color-text); font-family: var(--font-body-th); line-height: var(--leading-body);">
    <slot />
  </body>
</html>
