# Both values are PUBLIC (a LIFF id and a Lambda Function URL) and are baked into the SPA at build
# time. Copy to `.env` (or pass as env vars to `vite build`) once they're known from the deploy +
# LINE console registration. See plans/14-line-mini-app.md → "bootstrap ordering".

# The LIFF ID from the MINI App channel's Web app settings (NOT the channel id).
VITE_LIFF_ID=0000000000-xxxxxxxx

# The read-api Lambda Function URL (Pulumi output `readApiUrlOutput`), no trailing slash needed.
VITE_READ_API_URL=https://xxxxx.lambda-url.ap-southeast-1.on.aws
