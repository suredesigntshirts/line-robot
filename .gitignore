# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Test coverage
coverage/

# Secrets / env
.env
.env.*
!.env.example
# Local scratch file where the user pastes LINE credentials before they're
# loaded into Pulumi config — must never be committed.
LINE.md

# Pulumi
Pulumi.*.yaml.bak
.pulumi/

# Logs / OS
*.log
.DS_Store

# Claude Code — share project settings, keep personal overrides local
.claude/settings.local.json

# Editor swap files (may contain secret contents of files being edited)
*.swp
*.swo

# Playwright CLI scratch (profiles/screenshots from the skill)
.playwright-cli/

# Playwright e2e artifacts (plan 20) — defensive root rule in case a run is launched from the repo
# root instead of packages/website (the real output lives under packages/website/, gitignored there).
test-results/
playwright-report/
.last-run.json

# Astro generated types + bundled lambda output (rebuildable)
.astro/
dist-lambda/
packages/ui/gallery/dist
