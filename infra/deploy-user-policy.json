{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "GlobalReadOnlyPulumiNeeds",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity",
        "tag:GetResources",
        "dynamodb:ListTables",
        "s3:ListAllMyBuckets",
        "sqs:ListQueues",
        "lambda:ListFunctions",
        "lambda:ListEventSourceMappings",
        "ssm:DescribeParameters",
        "logs:DescribeLogGroups",
        "cloudfront:ListDistributions",
        "cloudfront:ListOriginAccessControls",
        "rds:Describe*",
        "rds:ListTagsForResource",
        "ec2:DescribeVpcs",
        "ec2:DescribeSubnets",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeSecurityGroupRules",
        "ec2:DescribeAvailabilityZones",
        "ec2:DescribeNetworkInterfaces",
        "ec2:DescribeAccountAttributes",
        "ec2:DescribeRouteTables",
        "ec2:DescribeInternetGateways"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ProjectScopedServices",
      "Effect": "Allow",
      "Action": ["dynamodb:*", "sqs:*", "ssm:*", "events:*", "rds:*"],
      "Resource": [
        "arn:aws:dynamodb:ap-southeast-1:259543826733:table/linerobot-*",
        "arn:aws:dynamodb:ap-southeast-1:259543826733:table/linerobot-*/index/*",
        "arn:aws:sqs:ap-southeast-1:259543826733:linerobot-*",
        "arn:aws:ssm:ap-southeast-1:259543826733:parameter/linerobot-*",
        "arn:aws:events:ap-southeast-1:259543826733:rule/linerobot-*",
        "arn:aws:rds:ap-southeast-1:259543826733:db:linerobot-*",
        "arn:aws:rds:ap-southeast-1:259543826733:subgrp:linerobot-*",
        "arn:aws:rds:ap-southeast-1:259543826733:pg:linerobot-*"
      ]
    },
    {
      "Sid": "S3",
      "Effect": "Allow",
      "Action": ["s3:*"],
      "Resource": ["arn:aws:s3:::linerobot-*", "arn:aws:s3:::linerobot-*/*"]
    },
    {
      "Sid": "LogsScoped",
      "Effect": "Allow",
      "Action": ["logs:*"],
      "Resource": [
        "arn:aws:logs:ap-southeast-1:259543826733:log-group:/aws/lambda/linerobot-*",
        "arn:aws:logs:ap-southeast-1:259543826733:log-group:/aws/lambda/linerobot-*:*"
      ]
    },
    {
      "Sid": "LambdaScoped",
      "Effect": "Allow",
      "Action": ["lambda:*"],
      "Resource": [
        "arn:aws:lambda:ap-southeast-1:259543826733:function:linerobot-*",
        "arn:aws:lambda:ap-southeast-1:259543826733:event-source-mapping:*"
      ]
    },
    {
      "Sid": "LambdaEventSourceMappings",
      "Effect": "Allow",
      "Action": [
        "lambda:CreateEventSourceMapping",
        "lambda:DeleteEventSourceMapping",
        "lambda:GetEventSourceMapping",
        "lambda:UpdateEventSourceMapping"
      ],
      "Resource": "*",
      "Condition": {
        "ArnLike": {
          "lambda:FunctionArn": "arn:aws:lambda:ap-southeast-1:259543826733:function:linerobot-*"
        }
      }
    },
    {
      "Sid": "IamRolesScopedToThisProject",
      "Effect": "Allow",
      "Action": ["iam:*"],
      "Resource": "arn:aws:iam::259543826733:role/linerobot-*"
    },
    {
      "Sid": "CloudFrontForMiniAppHosting",
      "Effect": "Allow",
      "Action": ["cloudfront:*"],
      "Resource": "arn:aws:cloudfront::259543826733:*"
    },
    {
      "Sid": "Ec2SecurityGroupsForRds",
      "Effect": "Allow",
      "Action": [
        "ec2:CreateSecurityGroup",
        "ec2:DeleteSecurityGroup",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress",
        "ec2:ModifySecurityGroupRules",
        "ec2:CreateTags",
        "ec2:DeleteTags"
      ],
      "Resource": "*"
    }
  ]
}
